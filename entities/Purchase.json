{
  "name": "Purchase",
  "type": "object",
  "properties": {
    "purchase_number": {
      "type": "string",
      "description": "Internal purchase order number"
    },
    "supplier_id": {
      "type": "string"
    },
    "supplier_name": {
      "type": "string"
    },
    "supplier_invoice_number": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "gst_rate": {
            "type": "number"
          },
          "gst_amount": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "cgst_amount": {
      "type": "number",
      "default": 0
    },
    "sgst_amount": {
      "type": "number",
      "default": 0
    },
    "igst_amount": {
      "type": "number",
      "default": 0
    },
    "total_gst": {
      "type": "number"
    },
    "grand_total": {
      "type": "number"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "partial",
        "pending"
      ],
      "default": "pending"
    },
    "amount_paid": {
      "type": "number",
      "default": 0
    },
    "balance_due": {
      "type": "number"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "purchase_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ordered",
        "received",
        "cancelled"
      ],
      "default": "received"
    }
  },
  "required": [
    "purchase_number",
    "supplier_id",
    "items",
    "grand_total"
  ]
}