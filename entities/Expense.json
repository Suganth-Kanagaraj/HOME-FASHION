{
  "name": "Expense",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "rent",
        "electricity",
        "salary",
        "transport",
        "marketing",
        "maintenance",
        "packaging",
        "miscellaneous"
      ],
      "default": "miscellaneous"
    },
    "amount": {
      "type": "number"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "upi",
        "bank_transfer",
        "card"
      ],
      "default": "cash"
    },
    "expense_date": {
      "type": "string",
      "format": "date"
    },
    "receipt_url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "amount",
    "category"
  ]
}
